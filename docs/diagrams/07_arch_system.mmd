flowchart TB
    subgraph DATA[Data layer]
        D1[make_cohort.py<br/>synthetic patients, fixed seed] --> D2[(cohort.csv)]
    end
    subgraph EXP[Experiment layer]
        E1[exp1: quantum kernel<br/>Qiskit statevector]
        E2[exp2: QAOA<br/>Qiskit algorithms]
        E3[exp3: QCBM<br/>PennyLane]
    end
    subgraph OUT[Results]
        R1[(results/*.json)]
    end
    subgraph AI[Analysis layer]
        A1[quantum_analyst<br/>Claude, or offline rule]
    end
    subgraph SHOW[Presentation]
        P1[make_plots.py<br/>charts]
        P2[verdict_cards.json]
    end
    DRV[run_all.py<br/>one-command driver] --> DATA
    D2 --> E1 & E2 & E3
    E1 & E2 & E3 --> R1
    R1 --> A1 --> P2
    R1 --> P1

